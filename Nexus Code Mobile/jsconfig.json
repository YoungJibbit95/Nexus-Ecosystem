{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@nexus/api": [
        "../packages/nexus-core/src/api/index.ts"
      ],
      "@nexus/api/*": [
        "../packages/nexus-core/src/api/*"
      ]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "esnext",
      "dom"
    ],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": []
  },
  "include": [
    "src/components/**/*.js",
    "src/pages/**/*.jsx",
    "src/types/**/*.d.ts",
    "src/Layout.jsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/vite-plugins",
    "src/components/ui",
    "src/api",
    "src/lib"
  ]
}
