{
  "name": "nexus-ecosystem",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "setup": "node ./tools/setup-ecosystem.mjs",
    "api:source": "node ./tools/api-source-status.mjs",
    "control:ensure": "node ./tools/run-with-control-plane.mjs --quiet",
    "dev:main": "node ./tools/dev-main.mjs",
    "dev:main:web": "npm --prefix \"./Nexus Main\" run dev",
    "dev:mobile": "npm --prefix \"./Nexus Mobile\" run cap:android",
    "dev:mobile:android": "npm --prefix \"./Nexus Mobile\" run cap:android",
    "dev:mobile:ios": "npm --prefix \"./Nexus Mobile\" run cap:ios",
    "dev:mobile:web": "npm --prefix \"./Nexus Mobile\" run dev:web",
    "dev:code": "npm --prefix \"./Nexus Code\" run electron:dev",
    "dev:code-mobile": "npm --prefix \"./Nexus Code Mobile\" run cap:android",
    "dev:code-mobile:android": "npm --prefix \"./Nexus Code Mobile\" run cap:android",
    "dev:code-mobile:ios": "npm --prefix \"./Nexus Code Mobile\" run cap:ios",
    "dev:code-mobile:web": "npm --prefix \"./Nexus Code Mobile\" run dev:web",
    "dev:control": "npm --prefix \"../Nexus Control\" run dev",
    "dev:control:open": "node ./tools/dev-control-open.mjs",
    "dev:all": "node ./tools/dev-ecosystem.mjs --without-control-plane",
    "dev:all:no-open": "NEXUS_CONTROL_NO_OPEN=true node ./tools/dev-ecosystem.mjs --without-control-plane",
    "build:main": "npm --prefix \"./Nexus Main\" run electron:build:host",
    "build:main:installers": "npm --prefix \"./Nexus Main\" run electron:build:installers",
    "build:mobile": "npm --prefix \"./Nexus Mobile\" run build",
    "build:code": "npm --prefix \"./Nexus Code\" run electron:build:host",
    "build:code:installers": "npm --prefix \"./Nexus Code\" run electron:build:installers",
    "build:code-mobile": "npm --prefix \"./Nexus Code Mobile\" run build",
    "build:control": "npm --prefix \"../Nexus Control\" run build",
    "build:electron:installers": "npm run build:main:installers && npm run build:code:installers",
    "build:apps": "npm run build:main && npm run build:mobile && npm run build:code && npm run build:code-mobile && npm run build:control",
    "build:ecosystem": "node ./tools/build-ecosystem.mjs --with-android --with-installers",
    "build:ecosystem:fast": "node ./tools/build-ecosystem.mjs --skip-installers",
    "build": "npm run build:ecosystem",
    "build:all": "npm run build:ecosystem",
    "verify:single-react": "node ./tools/verify-single-react.mjs",
    "verify:ecosystem": "node ./tools/verify-ecosystem.mjs",
    "measure:startup-sync": "node ./tools/measure-startup-sync.mjs",
    "doctor:release": "node ./tools/release-doctor.mjs",
    "doctor:release:hosted": "node ./tools/release-doctor.mjs --hosted-ui",
    "dev:all:with-control-ui": "node ./tools/dev-ecosystem.mjs",
    "build:ecosystem:with-healthcheck": "node ./tools/build-ecosystem.mjs --with-control-plane --with-android --with-installers",
    "build:ecosystem:fast:with-healthcheck": "node ./tools/build-ecosystem.mjs --with-control-plane --skip-installers"
  }
}
