{
  "name": "nexus-ecosystem",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "setup": "node ./tools/setup-ecosystem.mjs",
    "api:private:sync": "node ./tools/private-api-sync.mjs",
    "api:private:source": "node ./tools/private-api-sync.mjs --print-source",
    "api:private:source:required": "node ./tools/private-api-sync.mjs --print-source",
    "control:ensure": "node ./tools/run-with-control-plane.mjs --quiet",
    "dev:main": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Main\" run electron:dev",
    "dev:main:web": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Main\" run dev",
    "dev:mobile": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Mobile\" run cap:android",
    "dev:mobile:android": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Mobile\" run cap:android",
    "dev:mobile:ios": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Mobile\" run cap:ios",
    "dev:mobile:web": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Mobile\" run dev:web",
    "dev:code": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Code\" run electron:dev",
    "dev:code-mobile": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Code Mobile\" run cap:android",
    "dev:code-mobile:android": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Code Mobile\" run cap:android",
    "dev:code-mobile:ios": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Code Mobile\" run cap:ios",
    "dev:code-mobile:web": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Code Mobile\" run dev:web",
    "dev:control": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Control\" run dev",
    "dev:control-plane": "node ./tools/control-plane-command.mjs dev",
    "dev:control:open": "node ./tools/dev-control-open.mjs",
    "dev:all": "node ./tools/dev-ecosystem.mjs",
    "dev:all:no-open": "NEXUS_CONTROL_NO_OPEN=true node ./tools/dev-ecosystem.mjs",
    "build:main": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Main\" run electron:build:host",
    "build:mobile": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Mobile\" run build",
    "build:code": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Code\" run electron:build:host",
    "build:code-mobile": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Code Mobile\" run build",
    "build:control": "node ./tools/run-with-control-plane.mjs -- npm --prefix \"./Nexus Control\" run build",
    "build:control-plane": "node ./tools/control-plane-command.mjs build",
    "build:electron:installers": "npm run build:main && npm run build:code",
    "build:apps": "npm run build:main && npm run build:mobile && npm run build:code && npm run build:code-mobile && npm run build:control",
    "build:ecosystem": "node ./tools/run-with-control-plane.mjs -- node ./tools/build-ecosystem.mjs --with-android --with-installers",
    "build:ecosystem:fast": "node ./tools/run-with-control-plane.mjs -- node ./tools/build-ecosystem.mjs --skip-installers",
    "build": "npm run build:ecosystem",
    "build:all": "npm run build:ecosystem",
    "verify:ecosystem": "node ./tools/verify-ecosystem.mjs",
    "doctor:release": "node ./tools/release-doctor.mjs",
    "doctor:release:hosted": "node ./tools/release-doctor.mjs --hosted-ui"
  }
}
