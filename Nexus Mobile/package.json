{
  "name": "nexus-mobile",
  "version": "4.0.0",
  "type": "module",
  "description": "modern code editor, notepad, reminder system and todo list",
  "author": "youngjibbit95",
  "scripts": {
    "dev": "npm run cap:android",
    "dev:web": "vite",
    "dev:android": "npm run cap:android",
    "dev:ios": "npm run cap:ios",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "cap:sync": "npx cap sync",
    "cap:android": "npm run cap:build:android && npx cap open android",
    "cap:ios": "npm run cap:build:ios && npx cap open ios",
    "cap:build:android": "npm run build && npx cap sync android",
    "cap:build:ios": "npm run build && npx cap sync ios"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "clsx": "^2.0.0",
    "framer-motion": "^10.18.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^4.4.7",
    "monaco-editor": "^0.44.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/app": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/ios": "^6.0.0"
  }
}
