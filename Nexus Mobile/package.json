{
  "name": "nexus-mobile",
  "version": "6.0.0",
  "type": "module",
  "description": "modern code editor, notepad, reminder system and todo list",
  "author": "youngjibbit95",
  "scripts": {
    "dev": "npm run cap:android",
    "dev:web": "vite",
    "dev:android": "npm run cap:android",
    "dev:ios": "npm run cap:ios",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "cap:sync": "npx cap sync",
    "cap:android": "npm run cap:build:android && npx cap open android",
    "cap:ios": "npm run cap:build:ios && npx cap open ios",
    "cap:build:android": "npm run build && npx cap sync android",
    "cap:build:ios": "npm run build && npx cap sync ios"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/status-bar": "^8.0.2",
    "@monaco-editor/react": "^4.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.5",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.184.0",
    "use-sync-external-store": "^1.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "overrides": {
    "picomatch": "2.3.2",
    "dompurify": "3.4.0"
  }
}
