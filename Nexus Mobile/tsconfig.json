{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@nexus/core": ["../packages/nexus-core/src/index.ts"],
      "@nexus/core/*": ["../packages/nexus-core/src/*"],
      "@nexus/api": ["../packages/nexus-core/src/api/index.ts"],
      "@nexus/api/*": ["../packages/nexus-core/src/api/*"]
    }
  },
  "include": ["src"]
}
