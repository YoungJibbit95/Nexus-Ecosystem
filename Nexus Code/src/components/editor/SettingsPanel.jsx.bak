              <span className="text-xs text-gray-500 uppercase tracking-widest">
                Farben
              </span>
              <div className="grid grid-cols-2 gap-4 mt-3">
                <div>
                  <NativeLabel className="text-gray-400 mb-1.5 block">
                    Primary Accent
                  </NativeLabel>
                  <div className="flex items-center gap-2">
                    <div
