{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "dist-electron",
    "rootDir": "electron",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": false
  },
  "include": ["electron"],
  "exclude": ["dist-electron", "node_modules"]
}
